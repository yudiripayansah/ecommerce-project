APP_NAME="EZ-Store"
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://ezstore.com

# Tenancy
CENTRAL_DOMAIN=ezstore.com

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql                   # Docker service name, NOT 127.0.0.1
DB_PORT=3306
DB_DATABASE=ezstore_central
DB_USERNAME=ezstore
DB_PASSWORD=GANTI_PASSWORD_KUAT_SEKALI
DB_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT  # Hanya untuk docker-compose MySQL init

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis                # Docker service name
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=.ezstore.com     # Titik di depan = berlaku semua subdomain
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=public

# ── Mail (gunakan Brevo / Mailgun / SES — jangan log) ────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=YOUR_SMTP_PASSWORD
MAIL_FROM_ADDRESS="noreply@ezstore.com"
MAIL_FROM_NAME="EZ-Store"

# ── Midtrans ──────────────────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=Mid-server-xxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ── RajaOngkir ────────────────────────────────────────────────────────────────
RAJAONGKIR_API_KEY=your_api_key
RAJAONGKIR_ORIGIN_CITY_ID=501

# ── WhatsApp (Fonnte) ─────────────────────────────────────────────────────────
FONNTE_TOKEN=
FONNTE_ADMIN_WHATSAPP=
